# NyayNet Configuration
# Copy this file to .env and fill in your values

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-xxx

# === Instagram Graph API ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# === Cyber Crime Portal ===
PORTAL_COMPLAINANT_NAME=
PORTAL_COMPLAINANT_EMAIL=
PORTAL_COMPLAINANT_PHONE=
PORTAL_COMPLAINANT_STATE=
PORTAL_COMPLAINANT_CITY=

# === Encryption ===
ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# === Database ===
DATABASE_PATH=data/nyaynet.db

# === Detection Thresholds ===
LOCAL_MODEL_HATE_THRESHOLD_HIGH=0.85
LOCAL_MODEL_HATE_THRESHOLD_LOW=0.4
DECISION_CONFIDENCE_THRESHOLD=0.85
MIN_OFFENSIVE_COMMENTS=3
COOLDOWN_HOURS=24

# === Notifications ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# === Feature Flags ===
REQUIRE_HUMAN_APPROVAL=true
USE_MOCK_CLIENT=true
